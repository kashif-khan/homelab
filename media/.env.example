# ============================================================
# General
# ============================================================
TZ=America/New_York
PUID=1000
PGID=1000

# ============================================================
# Network
# ============================================================
# LAN IP of the host machine — used to bind published ports so Portainer shows clickable links
# Run `hostname -I | awk '{print $1}'` on the host to find it
HOST_IP=10.0.0.x

# Local TLD for HTTPS access via Nginx Proxy Manager (must match proxy/.env LAN_TLD)
# Add a wildcard DNS record *.home.arpa → HOST_IP in your router or Pi-hole
# Then create proxy hosts in NPM, e.g.:  sonarr.home.arpa → http://HOST_IP:8989
LAN_TLD=lan

# ============================================================
# Paths
# ============================================================
# MEDIA_DIR is the root for all media files
# CONFIG_DIR is where per-service config subdirectories live
#
# Linux example:
MEDIA_DIR=/mnt/media
CONFIG_DIR=/mnt/media/configs
#
# Windows (Docker Desktop) example:
# Map \\server\share to a drive letter first (e.g. net use Z: \\lexiedge\media)
# then reference it as:
# MEDIA_DIR=/run/desktop/mnt/host/z
# CONFIG_DIR=/run/desktop/mnt/host/z/configs

# ============================================================
# Restart Policy
# ============================================================
# Max retries before Docker stops restarting a failed container (on-failure policy)
# gluetun uses 2x this value due to flaky VPN servers
RESTART_MAX_RETRIES=5

# ============================================================
# VPN
# ============================================================
# Choose ONE of the following configurations:

# ===== Option 1: PureVPN with OpenVPN (Recommended for simplicity) =====
VPN_SERVICE_PROVIDER=purevpn
VPN_TYPE=openvpn
OPENVPN_USER=YOUR_PUREVPN_SERVICE_USERNAME
OPENVPN_PASSWORD=YOUR_PUREVPN_SERVICE_PASSWORD
# SERVER_COUNTRIES=Canada
# DNS_SERVER=1.1.1.1

# ===== Option 2: PureVPN with WireGuard (Advanced) =====
# VPN_SERVICE_PROVIDER=custom
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=your_private_key_here
# WIREGUARD_PUBLIC_KEY=your_public_key_here
# WIREGUARD_ADDRESSES=your_vpn_ip/32
# WIREGUARD_ENDPOINT_IP=your_endpoint_hostname
# WIREGUARD_ENDPOINT_PORT=51820
# DOT=off

# ===== Option 3: AirVPN with WireGuard =====
# VPN_SERVICE_PROVIDER=airvpn
# VPN_TYPE=wireguard
# FIREWALL_VPN_INPUT_PORTS=your_forwarded_port
# WIREGUARD_PRIVATE_KEY=your_private_key
# WIREGUARD_PUBLIC_KEY=your_public_key
# WIREGUARD_PRESHARED_KEY=your_preshared_key
# WIREGUARD_ADDRESSES=your_vpn_ip
# SERVER_COUNTRIES=your_country
# SERVER_CITIES=your_city

# Health check duration
# HEALTH_VPN_DURATION_INITIAL=120s

# ============================================================
# Ports
# ============================================================
# Change the host (left) side only if you have conflicts — do NOT change container ports

# VPN-tunneled (routed through Gluetun)
QBITTORRENT_PORT=8083         # qBittorrent web UI
QBITTORRENT_TORRENT_PORT=6881 # qBittorrent torrent traffic (TCP/UDP)
NZBGET_PORT=6789              # NZBGet web UI
PROWLARR_PORT=9696            # Prowlarr web UI

# Direct
SONARR_PORT=8989              # Sonarr web UI
RADARR_PORT=7878              # Radarr web UI
LIDARR_PORT=8686              # Lidarr web UI
BAZARR_PORT=6767              # Bazarr web UI

# ============================================================
# Credentials
# ============================================================

