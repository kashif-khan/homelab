# General UID/GIU and Timezone
TZ=America/New_York
PUID=1000
PGID=1000

# VPN Configuration
# For PureVPN with WireGuard, use the following:
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard

# WireGuard Keys and Config
# Get these values from your PureVPN WireGuard configuration file
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_PUBLIC_KEY=your_public_key_here
WIREGUARD_ADDRESSES=your_vpn_ip/32
WIREGUARD_ENDPOINT_IP=your_endpoint_hostname
WIREGUARD_ENDPOINT_PORT=51820

# For AirVPN with WireGuard, use the following instead:
# VPN_SERVICE_PROVIDER=airvpn
# VPN_TYPE=wireguard
# FIREWALL_VPN_INPUT_PORTS=your_forwarded_port
# WIREGUARD_PRIVATE_KEY=your_private_key
# WIREGUARD_PUBLIC_KEY=your_public_key
# WIREGUARD_PRESHARED_KEY=your_preshared_key
# WIREGUARD_ADDRESSES=your_vpn_ip
# SERVER_COUNTRIES=your_country
# SERVER_CITIES=your_city

# Health check duration
HEALTH_VPN_DURATION_INITIAL=120s
