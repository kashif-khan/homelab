# ============================================================
# Common
# ============================================================

# User and group ID for file permissions (run `id` on the host to get these)
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Los_Angeles

# Base path on the host where all service configs are stored
CONFIG_BASE=/mnt/media/configs

# Path to your media library on the host
MEDIA_PATH=/mnt/media

# ============================================================
# Jellyfin
# ============================================================

# Public URL used by Jellyfin for external access (used for DLNA and app discovery)
# Set to your server's LAN IP or domain name
JELLYFIN_PUBLISHED_SERVER_URL=http://10.0.0.69

# Host ports for Jellyfin
JELLYFIN_PORT=8096
JELLYFIN_DISCOVERY_UDP=7359  # Service discovery (UDP)
JELLYFIN_DLNA_UDP=1900        # DLNA/client discovery (UDP)

# ============================================================
# Jellyseerr (media request manager)
# ============================================================

# Host port for Jellyseerr web UI
JELLYSEERR_PORT=5055

# ============================================================
# Jellystat (Jellyfin statistics dashboard)
# ============================================================

# Host port for Jellystat web UI
JELLYSTAT_PORT=3000

# PostgreSQL credentials for Jellystat's database
# Must match between jellystat-db and jellystat services
JELLYSTAT_POSTGRES_USER=postgres
JELLYSTAT_POSTGRES_PASSWORD=changeme

# Secret key used to sign JWTs for Jellystat authentication
# Generate with: openssl rand -hex 32
JELLYSTAT_JWT_SECRET=changeme
