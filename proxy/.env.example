# ============================================================
# Network / LAN TLS
# ============================================================
# Local TLD used for HTTPS proxy hosts in Nginx Proxy Manager.
# Set this to your chosen internal domain, e.g. "home.arpa", "lan", or "local".
# In NPM, create proxy hosts like:  jellyfin.<LAN_TLD>
# Then add a wildcard DNS entry in your router/Pi-hole pointing *.home.arpa → HOST_IP.
LAN_TLD=home.arpa

# LAN IP of the host machine — used to bind published ports
HOST_IP=10.0.0.x

# Base path where service config subdirectories are stored (must match other stacks)
CONFIG_DIR=/mnt/media/configs

# ============================================================
# Cloudflare DDNS
# ============================================================
# Cloudflare API token with Zone:DNS:Edit permission for your domain
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Comma-separated public domains to keep updated (no spaces)
# Example: DDNS_DOMAINS=example.com,jellyfin.example.com
DDNS_DOMAINS=example.com

# Set to true to proxy traffic through Cloudflare (hides origin IP)
DDNS_PROXIED=true

# ============================================================
# Netbird VPN
# ============================================================
# Setup key from your Netbird management console
NB_SETUP_KEY=your_netbird_setup_key_here
