# ============================================================
# Network / LAN TLS
# ============================================================
# Local TLD used for HTTPS proxy hosts in Nginx Proxy Manager.
# Must match the domain set in Pi-hole (Settings → DNS → Pi-hole domain name).
# In NPM, create proxy hosts like: jellyfin.<LAN_TLD>
# In Pi-hole, add a CNAME record for each service pointing to the host A record.
LAN_TLD=lan

# LAN IP of the host machine — used to bind published ports
HOST_IP=10.0.0.x

# Base path where service config subdirectories are stored (must match other stacks)
CONFIG_DIR=/mnt/media/configs

# ============================================================
# Nginx Proxy Manager ports
# ============================================================
# Change the host (left) side if port 80/443/81 conflict with another service.
# If CasaOS is running, move it off port 80 first:
#   sudo nano /etc/casaos/gateway.ini  →  change port = 80 to port = 7070
#   sudo systemctl restart casaos-gateway
NPM_HTTP_PORT=80
NPM_HTTPS_PORT=443
NPM_ADMIN_PORT=8181

# ============================================================
# Nginx Proxy Manager credentials
# ============================================================
# Used by the npm-init service to authenticate with the NPM API.
# Change these from the defaults after first login.
NPM_ADMIN_EMAIL=admin@example.com
NPM_ADMIN_PASSWORD=changeme

# ============================================================
# Cloudflare DDNS
# ============================================================
# Cloudflare API token with Zone:DNS:Edit permission for your domain
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Comma-separated public domains to keep updated (no spaces)
# Example: DDNS_DOMAINS=example.com,jellyfin.example.com
DDNS_DOMAINS=example.com

# Set to true to proxy traffic through Cloudflare (hides origin IP)
DDNS_PROXIED=true

# ============================================================
# Netbird VPN
# ============================================================
# Setup key from your Netbird management console
NB_SETUP_KEY=your_netbird_setup_key_here
